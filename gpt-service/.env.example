PORT=5002
# Must match main auth backend JWT_SECRET so browser tokens validate.
JWT_SECRET=your_jwt_secret_same_as_backend

# Hugging Face Inference Providers (fine-grained token with "Make calls to Inference Providers")
HF_API_TOKEN=
HF_MODEL=openai/gpt-oss-120b:fastest
HF_MODEL_FALLBACKS=meta-llama/Llama-3.1-8B-Instruct:fastest,Qwen/Qwen2.5-7B-Instruct:fastest

# MongoDB Atlas — database name for this service
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=content_transfer
